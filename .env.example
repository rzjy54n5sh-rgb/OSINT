# Supabase (read-only anon key in client; all writes server-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare (for npm run deploy)
# CLOUDFLARE_API_TOKEN= create at https://dash.cloudflare.com/profile/api-tokens (use "Edit Cloudflare Workers" template)
# CLOUDFLARE_ACCOUNT_ID= 32-character string from Dashboard → Workers & Pages → right sidebar "Account ID" (not your email)
